# GameCLI Agent — Environment Variables (optional)
#
# Copy this file to .env and fill in values as needed.
# API keys can also be entered in the dashboard UI at runtime.

# LLM Provider: gemini_cli | gemini_api | openrouter
# PROVIDER=gemini_api

# API key for your chosen provider (not needed for gemini_cli)
# API_KEY=your_api_key_here
